{
  "name": "acp",
  "version": "1.1.0",
  "description": "",
  "main": "index.js",
  "bin": {
    "acp": "./dist/app/cli/main.js",
    "acp-jsonrpc-stdio": "./dist/app/stdio/main.js"
  },
  "scripts": {
    "bump": "node scripts/acp-bump.mjs",
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json && node scripts/check-dist-runtime.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:agent-permissions": "node scripts/check-agent-doc-permissions.mjs",
    "check:env": "node scripts/check-env-example.mjs",
    "check:edge-runtime-pins": "node scripts/check-edge-runtime-pins.mjs",
    "check:file-size": "node scripts/check-file-size.mjs",
    "check:openapi": "vitest run src/infrastructure/http/openapi.test.ts",
    "openapi:generate": "pnpm build && node scripts/generate-openapi.mjs",
    "dogfood:codex": "node scripts/acp-codex-dogfood-smoke.mjs",
    "dogfood:codex:multi": "node scripts/acp-codex-dogfood-multi-agent.mjs",
    "dogfood:cli": "node scripts/acp-cli-dogfood-multi-agent.mjs",
    "dogfood:docker-cli": "node scripts/acp-docker-cli-dogfood.mjs",
    "dogfood:docker-self": "node scripts/acp-docker-self-dogfood.mjs",
    "dogfood:docker-ha": "node scripts/acp-docker-ha-dogfood.mjs",
    "dogfood:docker-edge": "node scripts/acp-docker-edge-smoke.mjs",
    "dogfood:docker-gh-sandbox": "node scripts/acp-docker-gh-sandbox.mjs",
    "quickstart": "node scripts/acp-docker-self-dogfood.mjs --quickstart",
    "acp:up": "docker compose --profile sqlite up -d --build",
    "acp:down": "docker compose --profile sqlite down",
    "acp:logs": "docker compose logs -f acp",
    "acp:ha:up": "docker compose --profile ha up -d --build",
    "acp:ha:down": "docker compose --profile ha down",
    "acp:ha:logs": "docker compose logs -f acp-ha",
    "acp:edge:up": "docker compose --profile sqlite --profile edge up -d --build",
    "acp:edge:down": "docker compose --profile sqlite --profile edge down",
    "acp:edge:logs": "docker compose logs -f traefik",
    "acp:ha:edge:up": "docker compose --profile ha --profile edge up -d --build",
    "acp:ha:edge:down": "docker compose --profile ha --profile edge down",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.7.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@effect/platform": "^0.96.2",
    "@effect/platform-node": "^0.107.0",
    "@effect/rpc": "^0.75.1",
    "@effect/sql": "^0.51.1",
    "@effect/sql-pg": "^0.52.1",
    "effect": "^3.21.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
