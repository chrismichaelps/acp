{
  "type": "object",
  "additionalProperties": false,
  "required": ["worker", "claimed", "conflicts", "completed", "lease_released"],
  "properties": {
    "worker": { "type": "string", "pattern": "^agent_worker_" },
    "claimed": {
      "type": "array",
      "items": { "type": "string", "pattern": "^work_" }
    },
    "conflicts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "completed": {
      "type": "array",
      "items": { "type": "string", "pattern": "^work_" }
    },
    "lease_released": { "type": "boolean" }
  }
}
